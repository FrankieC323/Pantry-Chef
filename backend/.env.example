# Copy this file to .env and fill in your own keys. .env is gitignored.

# Database -- defaults to local SQLite if unset, fine for dev/demo.
# For Postgres: postgresql://user:password@localhost:5432/pantry_chef
DATABASE_URL=sqlite:///./pantry_chef.db

# Get a free key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Get a free key (150 req/day) at https://spoonacular.com/food-api/console#Dashboard
SPOONACULAR_API_KEY=

# Must match wherever the frontend dev server runs (Vite default shown)
FRONTEND_ORIGIN=http://localhost:5173

# Food bank feature: set to true while building/testing the UI to skip live
# Claude calls entirely and return the canned fixture instead (free, instant).
# Flip to false for real prompt tuning, the demo walkthrough, and production.
USE_MOCK_API=false

# Staff accounts: REQUIRED before deploying anywhere real. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Anyone with this value can mint a valid login token for any username --
# treat it like a password, never commit it.
JWT_SECRET_KEY=

# Once your staff accounts exist, set this to false so the /api/auth/register
# endpoint stops accepting new signups from anyone who finds the URL.
ALLOW_OPEN_REGISTRATION=true
